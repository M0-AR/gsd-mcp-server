{
  "name": "@md0ar/gsd-mcp-server",
  "version": "2.1.0",
  "description": "MCP server for the GSD (Get Shit Done) lifecycle framework — manage specs, phases, milestones, and project state via MCP tools and resources",
  "mcpName": "io.github.M0-AR/gsd-mcp-server",
  "keywords": [
    "mcp", "gsd", "model-context-protocol", "opencode",
    "project-management", "lifecycle", "ai-tools",
    "claude", "cursor"
  ],
  "license": "MIT",
  "author": "Mohamad Al-Ashmar <moar.job@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/M0-AR/gsd-mcp-server.git"
  },
  "homepage": "https://github.com/M0-AR/gsd-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/M0-AR/gsd-mcp-server/issues"
  },
  "type": "module",
  "main": "index.js",
  "bin": {
    "gsd-mcp-server": "index.js"
  },
  "files": [
    "index.js",
    "test-all.mjs",
    "test-edge.mjs",
    "test-functional.mjs",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "test": "node test-all.mjs && node test-edge.mjs && node test-functional.mjs",
    "test:main": "node test-all.mjs",
    "test:edge": "node test-edge.mjs",
    "start": "node index.js",
    "prepublishOnly": "npm test",
    "preversion": "npm test",
    "version": "git add -A",
    "postversion": "git push && git push --tags"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "zod": "^3.23.0"
  }
}
